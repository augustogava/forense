    "00:21:48,00:21:49": "Quer assistir o menino?",
    "00:21:49,00:21:49": "Quer me ajudar?",
    "00:21:49,00:21:54": "Se você quer assistir os meninos, pode ir lá.",
    "00:21:54,00:21:56": "O que você fez aí?",
    "00:21:56,00:21:58": "Você quer assistir os meninos aqui?",
    "00:21:59,00:22:01": "Qualquer uma ajudada eu vou ir muito mais.",
    "00:22:01,00:22:10": "Quer assistir aqui para o papai?",
    "00:22:12,00:22:13": "O que você quer então?",
    "00:22:13,00:22:15": "Quer comer?",
    "00:22:15,00:22:19": "Quer beber?",
    "00:22:19,00:22:20": "Quer mexer?",
    "00:22:21,00:22:22": "Quer jantar?",
    "00:30:32,00:30:36": "Pega-me aqui para o papai.",
    "00:30:36,00:30:37": "Pega-me aqui.",
    "00:30:38,00:30:40": "O que você quer?",
    "00:30:51,00:30:52": "Sim.",
    "00:30:52,00:30:53": "Sim.",
    "00:41:57,00:41:59": "Você sabe da TVC que eu vou pegar?",
    "00:41:59,00:42:00": "Vou ficar com ela e com você?",
    "00:42:07,00:42:08": "Mesmo com a minha mãe?",
    "00:42:09,00:42:10": "Não sabe não, isso.",
    "00:42:15,00:42:16": "Tem que ver se é você,",
    "00:42:16,00:42:17": "se vai servir.",
    "00:42:17,00:42:20": "E se...",
    "00:42:22,00:42:23": "se embrulhar.",
    "00:42:31,00:42:33": "Mas vai pegar meio que horas.",
    "00:42:36,00:44:28": "Você comeu tudo?",
