  "segments": {
    "00:13:17,00:13:24": "Eu te aceio, tenta não vacilar, menino eu te aceio, amor é pra cuidar, se escapar não",
    "00:13:24,00:13:29": "não, caixa no meu coração, antes de sumir da sua vida só mais uma coisa vai ter no",
    "00:13:30,00:13:32": "É a última vez que eu vou falar",
    "00:13:32,00:13:35": "Vou falar enquanto é claro",
    "00:13:36,00:13:39": "Se eu não vou falar eu sigo em espera",
    "00:13:45,00:13:50": "Eu não quero mais que o que eu quero ser",
    "00:13:50,00:13:53": "Seja assim que é, aí se pode entrar",
    "00:13:53,00:13:56": "O que eu queria é amor",
    "00:13:56,00:14:04": "Não sei, não sei onde eu vou",
    "00:14:04,00:14:07": "Não sei onde eu vou, onde eu vou, onde eu vou",
    "00:14:07,00:14:08": "a gente faz agora",
    "00:14:08,00:14:10": "deixa a conta",
    "00:14:10,00:14:12": "pra aproveitarem por nós",
    "00:14:12,00:14:13": "eu",
    "00:14:13,00:14:27": "tenho amor",
    "00:14:27,00:14:31": "ao meu amor",
    "00:14:31,00:14:38": "eu te deixarei",
    "00:14:38,00:14:39": "perceber",
    "00:14:39,00:14:42": "que eu te amo",
    "00:14:42,00:14:44": "eu vou virar um vagabundo",
    "00:14:44,00:14:57": "eu já tenho",
    "00:14:57,00:14:57": "o meu",
    "00:14:59,00:15:01": "agora eu não entendo mais",
    "00:16:48,00:16:50": "Música"
  },
