  "segments": {
    "00:25:56,00:25:57": "Eu tinha sido muito frágil, né?",
    "00:25:57,00:25:58": "Não, mas...",
    "00:25:58,00:26:01": "Deve ter falido que eu era frágil, né?",
    "00:26:01,00:26:01": "Sim.",
    "00:26:02,00:26:04": "Não, eu não sou frágil.",
    "00:26:04,00:26:05": "Eu não sou frágil.",
    "00:26:06,00:26:07": "Eu não sou frágil.",
    "00:29:47,00:29:48": "que seja feita com licença",
    "00:29:48,00:29:52": "vai precisar de mamãe também",
    "00:29:52,00:29:55": "vai precisar de psicóloga também",
    "00:29:55,00:30:38": "eu não queria voltar aqui",
    "00:30:38,00:30:40": "porque eu não ia ter licença",
    "00:30:40,00:30:55": "só que eu tenho a sabedoria",
    "00:30:55,00:31:35": "você vai tomar?",
    "00:31:35,00:31:38": "porque você está pedindo e não está tomando",
    "00:31:38,00:31:40": "óbvio, eu mentirei e me jogava fora",
    "00:31:40,00:31:41": "porque você não tomou",
    "00:31:41,00:31:42": "vai",
    "00:32:32,00:32:33": "ele quer ser cego",
    "00:32:33,00:32:34": "o que?",
    "00:32:35,00:32:40": "ai meu Deus",
    "00:34:23,00:34:52": "E aí veio o tomássaro, e aí a gente, ainda nada, né, só o chifre mesmo melhora.",
    "00:34:52,00:35:04": "Faz uns cinco dias, a gente estava chamando para ir no hospital, febre, molestia, e ela",
    "00:35:04,00:35:11": "assim, tá bem, uma coisa que tosse muito, gago comente, acho que vocês conhecem, sabe?",
    "00:38:44,00:38:44": "Tchau."
  },
