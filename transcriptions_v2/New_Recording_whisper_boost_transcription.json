  "segments": {
    "00:04:21,00:04:25": "Tchau, tchau.",
    "00:04:25,00:04:27": "industrial. O projeto faz parte",
    "00:04:27,00:04:29": "do novo ciclo de planejamento estratégico",
    "00:04:29,00:04:31": "do país e trata o meio de",
    "00:04:31,00:04:33": "tecnologias avançadas como a prioridade",
    "00:04:33,00:04:35": "de segurança nacional. A estratégia",
    "00:04:35,00:04:37": "reflete a visão do governo de",
    "00:04:37,00:04:39": "Xi Jinping de criar as chamadas",
    "00:04:39,00:04:41": "novas forças de foco",
    "00:04:42,00:04:44": "em áreas como IA, semiconsultores",
    "00:04:44,00:04:46": "e inovação industrial. A meta",
    "00:04:46,00:04:48": "é reduzir a dependência de tecnologias",
    "00:04:48,00:04:49": "estrangeiras, especialmente",
    "00:04:49,00:04:52": "diante das restrições de exportação",
    "00:04:52,00:04:54": "impostas pelos Estados Unidos",
    "00:04:54,00:04:57": "e aumentar a autossuficiência tecnológica do país.",
    "00:04:57,00:05:03": "Ao mesmo tempo, a aposta em tecnologia surge em meio a desamoros econômicos estruturais,",
    "00:05:03,00:05:09": "como o envelhecimento da população, a crise do setor imobiliário e o crescimento mais lento do consumo.",
    "00:05:33,00:05:35": "O que é isso?",
    "00:05:37,00:06:02": "O que é isso?",
    "00:08:10,00:08:10": "O que?",
    "00:08:16,00:08:16": "Alvarez?",
    "00:08:17,00:08:18": "Alvarez, super.",
    "00:08:18,00:08:18": "R$ 5,00 então.",
    "00:08:19,00:08:19": "Nossa senhora.",
    "00:08:21,00:08:24": "Que bom, põe R$ 100,00 gasolina.",
    "00:08:24,00:08:25": "Ou não?",
    "00:08:25,00:08:25": "Sim, cara.",
    "00:08:26,00:08:26": "Sim.",
    "00:08:34,00:08:35": "Ah, abri.",
    "00:08:35,00:08:36": "Aê.",
    "00:08:43,00:08:44": "Tá bebendo ou assistindo?",
    "00:09:37,00:09:38": "Obrigado, viu?",
    "00:09:38,00:09:39": "Fala.",
    "00:11:58,00:11:59": "Obrigado."
  },
