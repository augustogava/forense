  "segments": {
    "00:00:20,00:00:21": "O que?",
    "00:00:25,00:00:28": "Eu não te tive a cena.",
    "00:00:30,00:00:41": "Não, eu não te tive a cena.",
    "00:00:47,00:00:51": "Eu não te tive a cena.",
    "00:00:53,00:01:19": "Eu não te tive a cena.",
    "00:03:57,00:04:10": "Aí eu vou te passar as suas contas, né, e eu vou ter que guardar, e aí você maneja.",
    "00:04:10,00:04:11": "Pronto.",
    "00:04:11,00:04:15": "A gente está fazendo tudo de novo, entendeu?",
    "00:04:16,00:04:17": "Temos os paredes.",
    "00:04:17,00:04:18": "Nós temos que mudar eles.",
    "00:04:19,00:04:20": "Já.",
    "00:04:20,00:04:21": "Vamos juntas.",
    "00:04:21,00:04:22": "Vamos mudar eles.",
    "00:04:23,00:04:24": "Vamos fazer.",
    "00:04:24,00:04:27": "Aí depois você vai ter que parar o tratamento.",
    "00:04:27,00:04:28": "Por saúde.",
    "00:04:29,00:04:30": "Por sucesso.",
    "00:04:32,00:04:33": "Aí o cerebral.",
    "00:04:34,00:04:35": "É assim, entendeu?",
    "00:04:35,00:04:39": "Pode ser assim.",
    "00:04:40,00:04:43": "A gente mostra.",
    "00:04:43,00:04:45": "Como a gente consegue juntar aqui.",
    "00:04:45,00:04:47": "O plano.",
    "00:04:47,00:04:48": "O tratamento.",
    "00:04:48,00:04:48": "Como a gente consegue juntar aqui.",
    "00:04:48,00:04:56": "Mas, por enquanto, tá bom. Vai dar mais, se a gente fazer isso.",
    "00:04:58,00:04:59": "E seis mil pra mim, eu acho.",
    "00:05:00,00:05:01": "Quanto que a gente vai dar pra mim?",
    "00:05:03,00:05:04": "Seis mil reais.",
    "00:05:36,00:05:37": "Ai, meu Deus!",
    "00:05:38,00:05:39": "Já dá pra dar.",
    "00:05:41,00:05:41": "Muito.",
    "00:05:57,00:05:58": "Faz um grave pouco, né.",
    "00:05:58,00:05:58": "E?",
    "00:05:59,00:06:00": "Pouco, acho, né.",
    "00:06:05,00:06:07": "Às vezes, se a gente for tacando...",
    "00:06:07,00:06:07": "Você não vê isso, né?",
    "00:06:11,00:06:11": "Assim...",
    "00:06:11,00:06:12": "Tá.",
    "00:06:12,00:06:20": "Ele não tá tacando nada com ele, assim, né?",
    "00:06:21,00:06:21": "Não.",
    "00:06:23,00:06:25": "Mas ele faz só ele e você, por exemplo.",
    "00:06:26,00:06:26": "Não.",
    "00:06:27,00:06:29": "Por que não?",
    "00:06:29,00:06:30": "Não tem nada pra fazer os quatro.",
    "00:06:30,00:06:32": "Eu também não sei o que fazer.",
    "00:06:35,00:06:36": "Eu gastava cedo.",
    "00:06:37,00:06:44": "Eu acho que saiu uns mil.",
    "00:06:44,00:06:46": "Um milhão de juros.",
    "00:06:46,00:06:49": "Eu acho que saiu uns seis dólares.",
    "00:06:49,00:06:56": "Um motel lá de Naples.",
    "00:06:58,00:06:59": "Aí a alimentação.",
    "00:06:59,00:07:00": "Eu acho que eu já botei a palma.",
    "00:07:45,00:08:34": "Você já quer ir? Pode ir. Quer buscar?"
  },
