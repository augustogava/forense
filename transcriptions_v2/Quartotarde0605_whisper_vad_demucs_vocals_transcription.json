  "segments": {
    "00:59:40,00:59:42": "Está no chão da espirulina.",
    "00:59:42,00:59:44": "O amigo dela chegou lá no quinto.",
    "00:59:49,00:59:51": "Ela está ali. Ela está aqui.",
    "00:59:51,00:59:52": "Ela foi virar o atleta.",
    "00:59:53,00:59:55": "A escola está aqui.",
    "00:59:55,00:59:56": "A escola está aqui.",
    "01:00:03,01:00:08": "E os caras mal feitos saem lá na avenida, porque elas ficavam desmanteladas,",
    "01:00:08,01:00:15": "e a loja, eles falam assim, ali no barco, e eles só falam na hora de tirar a vez.",
    "01:00:24,01:00:33": "Aí, a gente foi lá, e a gente ficou, e a gente ficou lá também.",
    "01:00:33,01:00:34": "Obrigada."
