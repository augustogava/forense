  "segments": {
    "00:20:43,00:20:44": "Aqueles que são os pais, tudo é meu.",
    "00:20:48,00:20:49": "É muito bom, né?",
    "00:20:49,00:20:50": "Você vai preparar.",
    "00:20:51,00:20:53": "E não separa.",
    "00:20:53,00:20:56": "Então vai pra sua casa.",
    "00:20:58,00:20:59": "Vem também porque é você.",
    "00:20:59,00:21:01": "Você é assim.",
    "00:21:01,00:21:21": "Você não quer.",
    "00:21:22,00:23:28": "Quando eu chegar lá, eu saio, todo mundo vai me ver.",
    "00:23:28,00:23:30": "Eu falo, você tá me largando porque você tá me largando assim.",
    "00:23:30,00:23:33": "Você pode ser homem, você pode fazer as coisas direito na sua família.",
    "00:23:33,00:23:34": "Você tá me largando assim, doido assim.",
    "00:23:35,00:23:36": "Doido assim, tá? Tá.",
    "00:23:36,00:23:38": "Você pode ser homem, meio de gato, você pode me levar.",
    "00:23:39,00:23:39": "Você pode me apanhar.",
    "00:23:40,00:23:41": "Você pode me ver bem.",
    "00:23:41,00:24:11": "O que é isso?"
  },
