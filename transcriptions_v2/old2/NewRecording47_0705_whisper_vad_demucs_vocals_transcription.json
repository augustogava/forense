  "segments": {
    "00:01:28,00:06:40": "Você tá sujinho, de piscina, é melhor aguentar. Deixa eu me aguentar.",
    "00:06:41,00:13:07": "Oi Matias, não vai ficar vendo filme?",
    "00:13:07,00:13:15": "Vou dar banho em você, então. Você quer tomar banho com o papai?",
    "00:13:16,00:13:17": "O que você prefere?",
    "00:13:18,00:13:20": "Vamos lá encher a banheira?",
    "00:13:23,00:13:24": "Vamos lá encher a banheira.",
    "00:13:24,00:13:26": "É como um banho com o papai, você escolhe.",
    "00:13:26,00:13:33": "Vamos encher a banheira, vamos lá então.",
    "00:13:39,00:13:41": "Não tem essa, você tá lá na piscina, tem que tomar banho.",
    "00:13:41,00:13:45": "Você tá na escola, na piscina, não tem essa.",
    "00:13:45,00:13:46": "Vai numa banheira assim...",
    "00:13:47,00:13:51": "Não funciona assim, então não vamos no Panamá.",
    "00:13:51,00:13:53": "Eu vou pra uma banheira pra dormir.",
    "00:13:56,00:13:59": "No caso, você ir lá naquela banheira feita de cabeça.",
    "00:13:59,00:14:01": "Posso jogar uma feita de cabeça assim?",
    "00:14:01,00:14:01": "Tchum!",
    "00:14:03,00:14:03": "Tchum!",
    "00:14:06,00:14:07": "Não!",
    "00:15:15,00:21:49": "Quer me ajudar?",
    "00:21:49,00:21:54": "Se você quer assistir os mínimos do Panamá.",
    "00:21:54,00:21:56": "O que você fez aí?",
    "00:21:57,00:21:58": "Você quer assistir os meninos aqui?",
    "00:21:58,00:21:59": "Ai!",
    "00:21:59,00:22:00": "Qual que é a mais dada?",
    "00:22:00,00:22:01": "Eu vou em um colar.",
    "00:22:12,00:22:13": "O que você quer então?",
    "00:35:17,00:35:18": "Ele tomou TNT também?",
    "00:41:56,00:41:57": "Chegou a camiseta da Luísa.",
    "00:41:57,00:41:59": "Você sabe da TVC que eu vou pegar?",
    "00:42:07,00:42:07": "Ah, mesmo?",
    "00:42:08,00:42:08": "Eu não lembro.",
    "00:42:09,00:42:10": "Eu não sabe, não.",
    "00:42:10,00:42:16": "Eu tenho que ver se eu gostei.",
    "00:42:16,00:42:17": "Se vai servir.",
    "00:42:22,00:42:23": "Se embrulhar, hein?",
    "00:42:23,00:42:32": "Mas vai pegar amanhã que horas?",
    "00:44:27,00:44:28": "Foi tudo?",
    "01:18:10,01:18:11": "E a Lara?",
    "01:18:26,01:18:26": "E a Luna?",
    "01:18:26,01:18:27": "Como ela tá?",
    "01:18:27,01:19:37": "Me liga quando você chegar então.",
    "01:19:37,01:20:24": "Então, no final de vídeo, eu vou fazer a limpeza aqui.",
    "01:20:26,01:20:30": "Então, eu vou fazer a limpeza do dente e a limpeza do chácara de cada um."
  },
