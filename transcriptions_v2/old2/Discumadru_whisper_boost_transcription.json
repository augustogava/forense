  "segments": {
    "00:00:11,00:00:14": "Tá, mas eu vou estar junto, então.",
    "00:00:18,00:00:19": "Pode não é isso?",
    "00:00:32,00:00:35": "Não, você tava comendo de madrugada?",
    "00:00:37,00:00:39": "Então eu vou acordar de madrugada agora, todo dia, com você.",
    "00:00:39,00:00:39": "Não.",
    "00:00:40,00:00:41": "Não, por quê?",
    "00:00:41,00:00:45": "Porque eu tenho que trabalhar amanhã cedo.",
    "00:00:46,00:00:48": "Não, mas deixa eu, assim, não tem problema.",
    "00:00:49,00:00:50": "Sempre acordei.",
    "00:00:51,00:00:54": "Sky, do whatever.",
    "00:00:55,00:00:56": "O que vai mudar na minha vida?",
    "00:00:57,00:00:57": "Não, você tá...",
    "00:00:57,00:00:58": "A essa altura.",
    "00:00:59,00:01:01": "Então, deixa que eu dou a culpa de mamãe.",
    "00:01:01,00:01:03": "Deixa o leite.",
    "00:01:03,00:01:13": "Tô pegando o jeito já e todo mundo mais rápido.",
    "00:01:13,00:01:15": "Só quando tem a cansativa deles que não dorme.",
    "00:01:15,00:01:17": "Pouco mais dias acordam.",
    "00:01:18,00:01:19": "Eu perdi do dia, não é todo dia.",
    "00:01:21,00:01:22": "Tô conseguindo dormir à tarde.",
    "00:01:22,00:01:25": "Tô não conseguindo dormir à tarde.",
    "00:01:25,00:01:27": "Tô cansada, assim, né.",
    "00:01:27,00:01:30": "Pô, você acordou o dia que eu marquei a madrugada inteira.",
    "00:01:30,00:01:30": "Você fica acordada?",
    "00:01:32,00:01:33": "Você acabou de falar.",
    "00:01:33,00:01:37": "Que você passa a madrugada acordada.",
    "00:01:37,00:01:38": "Não falei.",
    "00:01:38,00:01:39": "Você falou.",
    "00:01:39,00:01:39": "Não falei.",
    "00:01:40,00:01:41": "Que você não dorme?",
    "00:01:41,00:01:42": "Que é cansativo?",
    "00:01:42,00:01:44": "Não, não falei isso.",
    "00:01:44,00:01:44": "Você falou isso agora.",
    "00:01:46,00:01:46": "Acabei de falar.",
    "00:01:46,00:01:48": "Vocês não sabem desse assunto.",
    "00:01:48,00:01:50": "Porque se eu estava conversando.",
    "00:01:50,00:01:53": "Você estava falando que é cansativo, que passa a madrugada.",
    "00:01:55,00:01:56": "Eu falei que ia te ajudar.",
    "00:01:57,00:02:03": "Eu não fico assistindo sozinha.",
    "00:02:03,00:02:03": "Então.",
    "00:02:04,00:02:04": "Sozinha.",
    "00:02:08,00:02:09": "Sozinha na minha mãe.",
    "00:02:09,00:02:10": "Como eu vou ficar sozinha?",
    "00:02:11,00:02:13": "Como é que eu vou cuidar dos dois?",
    "00:02:14,00:02:15": "Dormir com os dois um tempo?",
    "00:02:15,00:02:16": "Como é que eu vou dar banho com os dois?",
    "00:02:16,00:02:18": "Como é que eu vou cuidar da vida dos dois?",
    "00:02:18,00:02:18": "Como é que eu vou cuidar da minha mãe?",
    "00:02:18,00:02:19": "É isso que eu tô rolando.",
    "00:02:20,00:02:22": "Como é que eu vou ficar sozinha com dois?",
    "00:02:22,00:02:23": "Eu não sei nascer.",
    "00:02:24,00:02:25": "Não sei o que eu falo.",
    "00:02:26,00:02:26": "É isso.",
    "00:02:31,00:02:33": "Mas era isso que a gente tava vivendo.",
    "00:02:33,00:02:36": "Você era um companheiro de casa.",
    "00:02:39,00:02:41": "Colega que divide apartamento.",
    "00:02:41,00:02:42": "E me ajuda quando eu preciso.",
    "00:02:44,00:02:45": "Era isso que a gente tava vivendo."
  },
