  "segments": {
    "00:01:13,00:01:46": "Um, dois, três, quatro.",
    "00:11:23,00:11:24": "Eu te amo, meu amigo.",
    "00:11:27,00:12:47": "Eu te amo, meu amigo.",
    "00:38:02,00:38:04": "O que?",
    "00:38:06,00:38:08": "Essa é a nossa família.",
    "00:38:09,00:38:09": "O que?",
    "00:38:10,00:38:11": "Isso aqui?",
    "00:38:12,00:38:13": "Essa é a minha mãe que deu pra ele.",
    "00:38:14,00:38:17": "A mãe é a última que eu vou te dar.",
    "00:38:19,00:38:19": "Aqui?",
    "00:38:19,00:38:20": "É pra quem?",
    "00:38:21,00:38:21": "Aqui.",
    "00:38:24,00:38:26": "Ela tá ferrada do meu pai.",
    "00:38:26,00:38:27": "Do meu irmão pessoal.",
    "00:38:28,00:38:29": "Eu tenho ele e eu não tenho.",
    "00:38:30,00:38:32": "E essa família é minha irmã.",
    "00:38:34,00:38:34": "Por quê?",
    "00:38:35,00:38:36": "Por quê?",
    "00:38:40,00:38:40": "Muito afetivo.",
    "00:39:04,00:39:13": "Tudo bem. Tudo bem. Tudo bem.",
    "00:40:01,00:40:02": "Obrigado."
  },
