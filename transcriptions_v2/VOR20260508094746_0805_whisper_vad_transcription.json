  "segments": {
    "00:00:20,00:00:35": "A grande metropolitana está acumulado em dois mil reais.",
    "00:00:35,00:00:39": "E hoje, ao meio-dia, essa grana pode ser sua.",
    "00:00:40,00:00:42": "Eu me apanho.",
    "00:00:45,00:00:46": "Eu me apanho.",
    "00:01:13,00:01:57": "Hoje eu venço e eu me aliado à frente.",
    "00:06:39,00:06:40": "",
    "00:06:40,00:06:41": "Lá manda o Jão.",
    "00:06:41,00:06:43": "E agora faça a sua.",
    "00:06:43,00:06:45": "Então já dá a inscrição aí, manda as mãos em completo.",
    "00:06:46,00:06:50": "11-9-11-9-8-5-0.",
    "00:06:50,00:06:50": "Tá vendo?",
    "00:06:50,00:06:51": "O nosso apelo continua aqui.",
    "00:06:52,00:06:53": "É importante isso, é totalmente.",
    "00:06:53,00:06:55": "Fiz a metropolitana.",
    "00:06:55,00:06:57": "E agora, fora a simbólica.",
    "00:06:58,00:06:59": "Metroplane metropolitana.",
    "00:07:04,00:07:05": "A loura descarta.",
    "00:07:07,00:07:09": "A loura descarta."
  },
