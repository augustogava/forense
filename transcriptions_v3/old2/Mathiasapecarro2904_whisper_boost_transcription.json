  "segments": {
    "00:01:30,00:01:31": "Agradecer meu clima!",
    "00:01:33,00:01:35": "A partir do dia 5 de maio, toda terça,",
    "00:01:35,00:01:49": "e quando eu ouvir esse som,",
    "00:01:50,00:02:01": "a TV é a TV Disney.",
    "00:02:07,00:02:09": "A TV Disney 529.",
    "00:02:10,00:02:13": "Nesse frio, tem gente precisando de você.",
    "00:02:13,00:02:15": "Participe na campanha do agasalho.",
    "00:02:15,00:02:18": "No ideafix ou em outros pontos de arrecadação.",
    "00:03:02,00:03:05": "Você aprende na prática com projetos reais e vivências",
    "00:03:05,00:03:08": "que preparam você para o mercado de trabalho desde o início.",
    "00:03:08,00:03:09": "E o resultado aparece.",
    "00:11:16,00:11:18": "O seu Mickey veio passear?",
    "00:11:20,00:11:21": "Oi, Mickey!",
    "00:11:23,00:11:25": "Sabe onde a gente está indo?",
    "00:11:25,00:11:26": "Para a casa da vovó!",
    "00:11:27,00:11:28": "Para a casa da vovó?",
    "00:11:37,00:11:38": "Tá, segura o Mickey.",
    "00:11:38,00:11:38": "Já está chegando.",
    "00:11:50,00:11:50": "Meu Deus!",
    "00:11:50,00:11:51": "Não come!"
  },
