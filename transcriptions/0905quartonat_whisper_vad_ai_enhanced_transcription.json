    "00:18:36,00:18:36": ".",
    "00:21:22,00:21:22": ".",
    "00:40:23,00:40:24": "Obrigado.",
    "00:43:40,00:43:40": "Sim.",
    "00:49:33,00:49:34": "Estudo.",
    "00:55:03,00:55:04": "Não há mais.",
    "00:55:15,00:55:18": "Não é possível tomar banho, querendo tomar banho no outro quarto?",
    "00:55:23,00:55:23": "Cadê?",
    "00:55:51,00:55:53": "Deixa eu ver, me dá mais depois, por favor.",
    "00:55:54,00:55:54": "Não.",
    "00:55:55,00:55:56": "O que?",
    "00:55:56,00:55:57": "Vai deixar mais depois.",
    "00:55:58,00:55:59": "Como? Já foi aqui?",
    "00:56:00,00:56:00": "Veio.",
    "00:56:03,00:56:04": "Não é difícil, é comum, é...",
    "00:56:05,00:56:05": "Não?",
    "00:56:06,00:56:06": "Não.",
    "00:56:07,00:56:07": "Ah, não.",
    "00:56:07,00:56:09": "Eu não sei como é que eu vou falar, não sei o que é que eu vou falar.",
    "00:56:33,00:56:34": "Beijo.",
    "00:56:36,00:56:37": "Achei muito interessante.",
    "00:56:54,00:56:55": "Eu não te enxergo, agora.",
    "00:56:55,00:56:56": "Não, mostra-me.",
    "00:56:57,00:56:57": "Ela já chegou.",
    "00:56:58,00:56:59": "Não, já sou eu.",
    "00:56:59,00:57:03": "Não, não, não.",
    "00:57:05,00:57:06": "Não, não, não.",
    "00:57:10,00:57:10": "E aí",
    "00:58:11,00:58:11": "O que é isso?",
    "00:58:19,00:58:20": "O que é isso?",
    "00:58:29,00:58:30": "Atenção!",
    "00:58:36,00:58:37": "FIOR!",
    "00:58:47,00:58:47": "É loucura.",
    "01:00:19,01:00:20": "Atenção!",
    "01:00:37,01:00:37": "Não há problema.",
    "01:00:44,01:00:45": "Não, não, não, não.",
    "01:00:50,01:00:51": "Não, não tem nenhum.",
    "01:00:52,01:00:54": "Você não se parece com a vida do mamãe?",
    "01:00:54,01:00:55": "Não.",
    "01:00:55,01:00:57": "Eu quero mostrar para você minha filha.",
    "01:00:57,01:00:59": "Ela é uma dos meus filhos.",
    "01:01:00,01:01:02": "Aí a gente comeu.",
    "01:01:03,01:01:04": "Ah, ele faz.",
    "01:01:04,01:01:04": "Que bom!",
    "01:01:06,01:01:08": "Hum, não foi mesmo.",
    "01:01:08,01:01:09": "O que foi melhor de todo?",
    "01:01:11,01:01:12": "A gente tocou.",
    "01:01:14,01:01:15": "E a mamãe?",
    "01:01:15,01:01:16": "E a mamãe?",
    "01:01:17,01:01:18": "Não vai falar com você?",
    "01:01:19,01:01:20": "É, vou tu.",
    "01:01:22,01:01:23": "Ah, não, só te chamo.",
    "01:01:24,01:01:24": "Ah, vou tu.",
    "01:01:31,01:01:33": "Ela voltou só bem relácteos.",
    "01:01:36,01:01:37": "Um pouquinho.",
    "01:01:38,01:01:40": "Eu vou aqui.",
    "01:01:51,01:01:53": "Que isso? Uau!",
    "01:01:54,01:01:55": "Não é nada?",
    "01:01:56,01:01:57": "Que isso?",
    "01:01:58,01:02:00": "Ai, que bom que é!",
    "01:02:01,01:02:03": "Que profundo, chefe!",
    "01:02:05,01:02:07": "Você vai com a vovó?",
    "01:02:07,01:02:08": "Tá tendo vovó?",
    "01:02:08,01:02:09": "E aí, filha?",
    "01:02:10,01:02:12": "Ela veio faz tempo?",
    "01:02:13,01:02:14": "Sim, papi.",
    "01:02:16,01:02:16": "Agora vamos esperar.",
    "01:02:21,01:02:25": "Nossa! Isso é de infância?",
    "01:02:27,01:02:28": "Não, não é.",
    "01:02:28,01:02:30": "É uma chica.",
    "01:02:35,01:02:35": "Olha!",
    "01:02:40,01:02:42": "Não se apresse de me esforçar.",
    "01:02:49,01:02:50": "A gente já não conhece?",
    "01:02:51,01:02:52": "Não.",
    "01:02:55,01:02:57": "O que é que é isso?",
    "01:02:58,01:02:59": "Eu não sei."
