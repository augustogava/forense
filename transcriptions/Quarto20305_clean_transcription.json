  "segments": {
    "00:00:01,00:00:01": "Abençoe.",
    "00:07:18,00:07:18": "Não!",
    "00:07:29,00:07:31": "O pijaminha que a mamãe pegou, você lembra dele?",
    "00:07:33,00:07:34": "Lembra desse pijama?",
    "00:08:03,00:08:06": "Eu tô te esperando lá, você não vai descer pra ficar com o meu vovô antes da gente ir embora?",
    "00:08:14,00:08:16": "Ele quebrou a escova dele e agora?",
    "00:09:09,00:09:09": "Obrigado, pessoal!",
    "00:09:12,00:09:13": "Ainda!",
    "00:10:21,00:10:21": "A família.",
    "00:10:27,00:10:28": "Agradeceria muito.",
    "00:10:45,00:10:46": "Pois amei-a?",
    "00:10:48,00:10:48": "Ambro-me-a!",
    "00:10:52,00:10:53": "Não é querido.",
    "00:11:06,00:11:07": "Semana que vem a gente vai ficar aqui, tá?",
    "00:11:16,00:11:17": "Agora, descendo.",
    "00:11:19,00:11:19": "Três.",
    "00:11:25,00:11:25": "Até o próximo!",
    "00:27:16,00:27:18": "A estima que é inata, se você não é do outro lado.",
    "00:28:27,00:28:28": "O que são com a atitude?",
    "00:37:34,00:37:35": "Aplausos"
  },
