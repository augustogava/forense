  "segments": {
    "00:00:02,00:00:03": "Eu acho que eu escutei o Marlon.",
    "00:00:04,00:00:04": "Eu não entendi.",
    "00:00:04,00:00:05": "Eu nunca entendi.",
    "00:00:05,00:00:05": "Eu nunca entendi.",
    "00:16:40,00:16:40": ".",
    "00:42:31,00:42:32": "Submarino",
    "00:55:03,00:55:04": "Não é isso!",
    "00:55:17,00:55:17": "Nossa, meu meu Deus, menino.",
    "00:55:18,00:55:18": "Vamos para o quarto?",
    "00:55:35,00:55:39": "Atenção, o que eu estou dizendo é uma auto-mascada em número.",
    "00:55:49,00:55:50": "Atenção!",
    "00:56:11,00:56:11": "Veja.",
    "00:56:12,00:56:13": "Que gostosa.",
    "00:56:14,00:56:15": "Está tudo bem.",
    "00:56:15,00:56:16": "Arrojamos nossa mesa.",
    "00:56:17,00:56:18": "Coloquei dois bolos.",
    "00:56:18,00:56:18": "E agora, vamos fazer a nossa receita.",
    "00:56:22,00:56:23": "O que é que vai?",
    "00:56:25,00:56:28": "Nossa, eu sou sólida, filho da família, e desde a minha idade, só.",
    "00:56:30,00:56:32": "É a filha nossa que chama Letícia, Felipe, né?",
    "00:56:33,00:56:34": "Meu novo estágio, só eu.",
    "00:56:36,00:56:37": "Achei muito interessante isso.",
    "00:57:10,00:57:10": "E aí",
    "01:00:37,01:00:37": "Não é possível!",
    "01:00:49,01:00:51": "Hum, hum, não, não, não.",
    "01:00:52,01:00:54": "Não, não, não, não.",
    "01:00:55,01:00:56": "É que eu não sei a coisa.",
    "01:01:18,01:01:20": "Acompanhe o nosso canal no Facebook, no Instagram e no Twitter.",
    "01:01:22,01:01:23": "Não é um desatinho não?",
    "01:01:23,01:01:24": "Mas voltou.",
    "01:01:27,01:01:28": "Ouvirá!",
    "01:01:31,01:01:32": "Eu acho.",
    "01:01:36,01:01:37": "O Joguei.",
    "01:01:44,01:01:45": "Leandro Taqui",
    "01:01:54,01:01:55": "Muito bom, né?",
    "01:02:06,01:02:07": "Volta, tempo de volta!",
    "01:02:11,01:02:12": "Não vê pra tempo?",
    "01:02:16,01:02:16": "Então, vou te falar.",
    "01:02:21,01:02:25": "Nossa! Isso não era de infância?",
    "01:02:26,01:02:27": "Não.",
    "01:02:35,01:02:35": "Ah, e é!"
