  "segments": {
    "00:00:01,00:00:02": "Eu já fiz essa notícia com o Tomás.",
    "00:55:14,00:55:16": "Eu bebi banho, não consegui tomar banho.",
    "00:55:16,00:55:17": "Cadê o Tomás?",
    "00:55:17,00:55:17": "Onde é o banheiro?",
    "00:55:43,00:55:46": "Vou pedir para ele ligar a banheira para me dar banho.",
    "00:55:46,00:55:48": "Se não, eu vou estar dormindo na cama.",
    "00:55:48,00:55:50": "Vou pedir para ele ligar, que eu dou banho rapidinho.",
    "00:55:51,00:55:53": "Deixa eu descer, meu. Eu dou banho depois.",
    "00:55:56,00:55:57": "Vai deixar de ver depois.",
    "00:55:58,00:55:59": "Como?",
    "00:55:59,00:55:59": "Já está aqui?",
    "00:55:59,00:56:01": "Já ia lhe recordar.",
    "00:56:03,00:56:04": "Mas está com ele.",
    "00:56:05,00:56:05": "Não?",
    "00:56:06,00:56:06": "Não.",
    "00:56:06,00:56:09": "Tá bom, então vamos lá no troca.",
    "00:56:13,00:56:16": "Tá tudo bem, a vó já arrumou as mesas.",
    "00:56:16,00:56:18": "A vó fez dois bolos.",
    "00:56:25,00:56:29": "Eu sou só a avó da família, com dois amigos do pai e só.",
    "00:56:30,00:56:32": "Ela que chama Letícia, Felipe, né?",
    "00:56:32,00:56:34": "Eu não, eu gosto tanto, só a gente.",
    "00:56:36,00:56:37": "Achei que não fosse muito bom.",
    "00:56:55,00:57:04": "Acompanhe a transmissão em português.",
    "01:00:36,01:00:37": "Porto.",
    "01:00:43,01:00:46": "Seja bem-vindo!",
    "01:00:50,01:00:51": "Não é o mesmo?",
    "01:00:56,01:01:04": "A gente fez a alimentação, pegou as brincadeiras, aí a gente comeu, e fomos.",
    "01:01:08,01:01:09": "Médicos.",
    "01:01:17,01:01:20": "Ela voltou.",
    "01:01:23,01:01:23": "Não tô aqui não.",
    "01:01:23,01:01:24": "Não voltou.",
    "01:01:27,01:01:27": "Tchau!",
    "01:01:31,01:01:32": "A rota sozinha é lógica.",
    "01:01:37,01:01:37": "O que é o que?",
    "01:01:39,01:01:40": "É uma linda voz, né?",
    "01:01:40,01:01:41": "É uma linda voz.",
    "01:01:41,01:01:42": "É uma linda voz.",
    "01:01:44,01:01:45": "A gente está aqui.",
    "01:02:11,01:02:12": "Faz tempo?"
  },
