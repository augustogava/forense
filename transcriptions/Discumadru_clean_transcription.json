  "segments": {
    "00:00:07,00:00:08": "Você me acorda?",
    "00:00:08,00:00:10": "Não, não é isso.",
    "00:00:12,00:00:13": "Tá, mas eu vou estar junto.",
    "00:00:18,00:00:18": "Pode demorar.",
    "00:00:32,00:00:33": "Nossa, você tá comendo de...",
    "00:00:35,00:00:35": "de madrugada?",
    "00:00:36,00:00:36": "Sim.",
    "00:00:37,00:00:39": "Então eu vou acordar de madrugada agora todo dia com você.",
    "00:00:39,00:00:40": "Não.",
    "00:00:40,00:00:40": "Sim.",
    "00:00:40,00:00:41": "Não? Por quê?",
    "00:00:46,00:00:50": "Não, mas deixa, não tem problema. Sempre acordei.",
    "00:00:53,00:00:56": "O que vai mudar na minha vida?",
    "00:00:57,00:00:58": "Nessa altura.",
    "00:00:59,00:01:01": "Então, deixa que eu dou a hora de mamar.",
    "00:01:02,00:01:03": "Deixa o leite.",
    "00:01:09,00:01:17": "Eu não tô mais reclamando, eu tô pegando jeito já, ele tá dormindo mais rápido, só que é cansativo às vezes, ele não dorme, ou o Matias acorda.",
    "00:01:18,00:01:19": "Eu perdi do dia, não é todo dia.",
    "00:01:21,00:01:23": "Eu tô conseguindo dormir à tarde, aí eu fico cansada.",
    "00:01:24,00:01:27": "Quando eu não consigo dormir à tarde, eu fico cansada, enfim, né?",
    "00:01:27,00:01:30": "Você acabou de reclamar que a madrugada inteira você fica acordada?",
    "00:01:31,00:01:32": "Eu não falei isso, que é só o que eu disse.",
    "00:01:33,00:01:33": "Você acabou de falar?",
    "00:01:35,00:01:53": "Você passa a madrugada acordada? Não falei. Você falou. Não falei. Você não dorme? Tensativo? Não falei. Você falou isso agora. Acabei de falar. Eu não saí nesse assunto. Porque a Caetano estava conversando, você estava falando que é cansativo, que você passa a madrugada.",
    "00:01:56,00:01:57": "Eu falei que ia te ajudar. Então...",
    "00:02:26,00:02:27": "Não?",
    "00:02:31,00:02:36": "Mas era isso que a gente estava vivendo. Você era um companheiro de casa?",
    "00:02:36,00:02:42": "Um colega que divide apartamento e me ajuda quando eu preciso.",
    "00:02:44,00:02:45": "Era isso que a gente estava vivendo.",
    "00:02:46,00:02:47": "Qual é o seu nome, amor?",
    "00:02:47,00:02:48": "Marido, mulher.",
    "00:02:48,00:02:49": "O que?",
    "00:02:49,00:02:50": "Você está vivendo com a mulher.",
    "00:02:51,00:02:52": "O que é isso?"
  },
  "explicit_segments": {
