  "segments": {
    "00:00:01,00:00:02": "Agradeço a presença.",
    "00:07:29,00:07:31": "Também realmente é bom, você lembra dele?",
    "00:07:33,00:07:34": "Lembra desse pijama?",
    "00:08:03,00:08:06": "Eu tô te esperando lá, você não vai descer? Vamos, a gente embora?",
    "00:08:14,00:08:15": "Amém.",
    "00:08:15,00:08:16": "De amor.",
    "00:08:16,00:08:17": "Fica.",
    "00:08:22,00:08:38": "Atenção, o vídeo está em curto tempo de gravação.",
    "00:08:40,00:08:40": "Não tem.",
    "00:08:57,00:08:57": "Obrigada.",
    "00:09:04,00:09:04": "Obrigada.",
    "00:09:07,00:09:08": "Obrigado!",
    "00:09:13,00:09:15": "Seu...",
    "00:09:15,00:09:16": "Cão!",
    "00:09:27,00:09:27": "O que você acabou?",
    "00:09:31,00:09:32": "Eu te sinto.",
    "00:09:39,00:09:39": ".",
    "00:09:55,00:10:05": "Acompanhe a transmissão em português.",
    "00:10:08,00:10:10": "É isso aí.",
    "00:10:11,00:10:14": "É isso aí.",
    "00:10:15,00:10:16": "Ó, vem esse aqui.",
    "00:10:19,00:10:19": "Não!",
    "00:10:20,00:10:21": "É essa a minha ideia.",
    "00:10:23,00:10:24": "Não pode abrir!",
    "00:10:26,00:10:27": "Deixa eu ver se não me apertei.",
    "00:10:32,00:10:33": "Assim, né?",
    "00:10:38,00:10:39": "Essa aqui fica fácil, né?",
    "00:10:52,00:10:53": "Não é pra ele.",
    "00:10:58,00:11:00": "Brinquedo, filho, que a gente vê aqui na rua.",
    "00:11:06,00:11:07": "Não é que veja essa que faz.",
    "00:11:16,00:11:17": "Receba.",
    "00:11:18,00:11:19": "É isso.",
    "00:11:25,00:11:25": "Até a próxima!"
  },
