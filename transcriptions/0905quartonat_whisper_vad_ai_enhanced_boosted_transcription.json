    "00:43:18,00:43:20": "Atenção!",
    "00:43:40,00:43:40": "Sim.",
    "00:47:39,00:47:39": ".",
    "00:55:03,00:55:04": "Não há mais.",
    "00:55:15,00:55:18": "Não é possível tomar banho, porque eu vou tomar banho no outro quarto.",
    "00:55:23,00:55:23": "Cadê?",
    "00:55:51,00:55:53": "Deixa eu ver, me dá mais depois, por favor.",
    "00:55:54,00:55:54": "Não.",
    "00:55:55,00:55:56": "O que?",
    "00:55:56,00:55:57": "Vai deixar mais depois.",
    "00:55:58,00:55:59": "Como? Já tô aqui?",
    "00:56:00,00:56:00": "Veio.",
    "00:56:03,00:56:04": "Não é difícil, é comum, é...",
    "00:56:05,00:56:05": "Não?",
    "00:56:06,00:56:06": "Não.",
    "00:56:07,00:56:07": "Ah, não.",
    "00:56:07,00:56:09": "Eu não sei como é que eu vou falar, não sei o que é que eu vou falar.",
    "00:56:33,00:56:34": "Beijo.",
    "00:56:36,00:56:37": "Achei muito interessante.",
    "00:56:54,00:56:55": "Eu vou te fechar agora.",
    "00:56:55,00:56:56": "E mostra-me.",
    "00:56:56,00:56:57": "Ela já chegou.",
    "00:56:58,00:56:59": "Não, eu já sou a capa.",
    "00:56:59,00:57:01": "Você vai fechar?",
    "00:57:02,00:57:03": "Eu vou fechar.",
    "00:57:05,00:57:06": "Não, não, porque...",
    "00:57:06,00:57:06": "Tá bom.",
    "00:58:19,00:58:20": "O que é isso?",
    "00:58:29,00:58:30": "Atenção!",
    "00:58:36,00:58:37": "Tchau!",
    "00:58:47,00:58:47": "É loucura.",
    "01:00:19,01:00:20": "E o que é o nosso conserto?",
    "01:00:36,01:00:37": "É bom pra...",
    "01:00:43,01:00:44": "Que rápido vocês foram!",
    "01:00:49,01:00:51": "Não, não, não.",
    "01:00:52,01:00:54": "Você não tomará o papo do mamão?",
    "01:00:54,01:00:55": "Não.",
    "01:00:55,01:00:57": "É que eu não sei a apresentação.",
    "01:00:57,01:00:59": "Agora as bicheiras.",
    "01:01:00,01:01:02": "Aí a gente comeu.",
    "01:01:02,01:01:04": "Ali faz.",
    "01:01:04,01:01:04": "Tem mais.",
    "01:01:06,01:01:08": "Não fumei.",
    "01:01:08,01:01:09": "O que foi melhor de tomar?",
    "01:01:10,01:01:12": "A gente tocou.",
    "01:01:14,01:01:16": "E a mamãe?",
    "01:01:17,01:01:18": "Não vai andar com você?",
    "01:01:19,01:01:21": "É, eu vou ter um...",
    "01:01:22,01:01:23": "Ah, não, só que não.",
    "01:01:24,01:01:24": "Ah, voltou?",
    "01:01:31,01:01:32": "Ela voltou só bem relaxada.",
    "01:01:36,01:01:37": "Um pouquinho.",
    "01:01:38,01:01:40": "Eu vou aqui.",
    "01:01:51,01:01:53": "Que linda! Uau!",
    "01:01:54,01:01:55": "Não é nada?",
    "01:01:56,01:01:57": "Que linda!",
    "01:01:58,01:02:00": "Ai, que bonitinha!",
    "01:02:01,01:02:02": "Que profunda!",
    "01:02:05,01:02:07": "Você vai com a vovó?",
    "01:02:07,01:02:07": "Vai com a vovó?",
    "01:02:08,01:02:09": "E aí, tia?",
    "01:02:10,01:02:12": "Ela veio faz tempo?",
    "01:02:13,01:02:14": "Sim, tia.",
    "01:02:16,01:02:16": "Agora vamos esperar.",
    "01:02:21,01:02:25": "Nossa! Isso é de infância?",
    "01:02:27,01:02:28": "Não, não é.",
    "01:02:28,01:02:30": "É uma chica.",
    "01:02:34,01:02:35": "Olha!",
    "01:02:44,01:02:45": "Obrigado.",
    "01:02:49,01:02:50": "A gente já não conhece?",
    "01:02:51,01:02:52": "Não.",
    "01:02:55,01:02:57": "O que é que é isso?",
    "01:02:58,01:02:59": "Eu não sei."
