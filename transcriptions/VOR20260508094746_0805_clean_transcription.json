  "segments": {
    "00:00:20,00:00:21": "E um beijo à frente.",
    "00:00:30,00:00:39": "A grande metropolitana está acumulada em dois mil reais. E hoje, ao meio dia, essa grana pode ser sua.",
    "00:01:09,00:01:09": ".",
    "00:01:56,00:01:56": "Obrigada.",
    "00:03:50,00:03:51": "Abertura da tradutora",
    "00:04:31,00:04:36": "A gente se prendendo a torva, não faz nada de trapezoide.",
    "00:04:37,00:04:43": "Não dá pra saber que a dor não tem fim.",
    "00:04:55,00:05:09": "Acompanhe o vídeo e saiba como fazer um bom trabalho.",
    "00:05:12,00:05:13": "Atenção!",
    "00:05:23,00:05:40": "Acompanhe o vídeo em seu celular ou no seu smartphone.",
    "00:06:11,00:06:12": "E aí",
    "00:06:12,00:06:13": "E aí",
    "00:06:19,00:06:22": "É o mundo aquele medo do...",
    "00:06:49,00:06:51": "E o Metroplay continua aqui.",
    "00:06:52,00:06:53": "E perto de se acertar.",
    "00:06:53,00:06:55": "E na Metropolitana.",
    "00:06:55,00:06:57": "Duas horas de música.",
    "00:06:58,00:06:59": "Metroplay Metropolitana.",
    "00:07:09,00:07:11": "E aí"
  },
