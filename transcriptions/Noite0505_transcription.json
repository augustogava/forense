  "segments": {
    "00:00:05,00:00:07": "Uhum, uhum.",
    "00:00:10,00:00:10": "Uhum.",
    "00:02:28,00:02:29": "Por fim...",
    "00:02:46,00:02:46": "Eba!",
    "00:05:25,00:05:26": "Apesar de ser um assunto muito importante, o que é mais importante é a sua vida.",
    "00:06:12,00:06:15": "Por os meus sentimentos no lugar do seu",
    "00:06:15,00:06:15": "Não",
    "00:06:15,00:06:18": "Você acha que eu tenho que sentir mais gosto de você",
    "00:06:18,00:06:19": "Entender mais gosto de você",
    "00:06:19,00:06:20": "Não, pra mim não foi",
    "00:06:20,00:06:22": "Se eu tivesse sido eu tinha falado pra você",
    "00:06:22,00:06:23": "Não preciso mais ver, não quero mais ver",
    "00:06:24,00:06:25": "Eu te mando",
    "00:06:25,00:06:26": "Fala o que tá",
    "00:06:27,00:06:28": "Faz o exame",
    "00:06:30,00:06:32": "Não é questão de dúvida, é questão de eu ficar tranquila só.",
    "00:06:32,00:06:34": "Então, você vai ficar tranquila.",
    "00:06:34,00:06:35": "Você vai ficar tranquila.",
    "00:06:36,00:06:37": "Não, pra que você precisa fazer exame?",
    "00:06:37,00:06:39": "Se eu posso só ver se você não tá gastando dinheiro todo.",
    "00:06:40,00:06:42": "Se eu não tava fazendo a exame, você tem que dominar as respostas.",
    "00:06:43,00:06:44": "Não, eu vou te levar.",
    "00:06:44,00:06:46": "Não, você ficou longe de falar que não vai.",
    "00:06:46,00:06:47": "Eu vou te levar.",
    "00:06:48,00:06:49": "Eu vou te mandar.",
    "00:06:49,00:06:50": "Eu quero falar o valor.",
    "00:06:51,00:06:52": "Não, eu vou te mandar.",
    "00:06:52,00:06:53": "Eu quero falar o valor.",
    "00:06:54,00:06:55": "Você falava o valor pra mim, Danilo.",
    "00:06:56,00:06:57": "Ah, meu cartão veio seis...",
    "00:06:57,00:06:58": "Como que veio seis mil?",
    "00:06:59,00:07:00": "Aí você me molava, né?",
    "00:07:00,00:07:01": "Ah, eu vou te mandar, relaxa.",
    "00:07:03,00:07:03": "Agora...",
    "00:07:03,00:07:04": "Agora...",
    "00:07:37,00:07:39": "Não há remédio? É psicólogo.",
    "00:08:11,00:08:11": "Aqui?",
    "00:15:16,00:15:20": "Apenas o que for dito, não é o que é.",
    "00:18:40,00:18:40": "Hum!",
    "00:20:07,00:20:07": "Oi!",
    "00:20:09,00:20:09": "Oi!",
    "00:20:51,00:20:51": "Aum."
  },
