    "00:02:56,00:02:56": "Não.",
    "00:32:11,00:32:12": "Não há dúvidas.",
    "00:32:49,00:32:49": ".",
    "00:38:30,00:38:31": ".",
    "00:38:49,00:38:55": "Não, pode vir. Já avisei a mãe ali pra não dar banho nele não. Aí tá uma corrida.",
    "00:38:55,00:38:58": "Eu vou pra uma tia e vou ficar com ela dando banho.",
    "00:38:59,00:39:01": "Amanhã quero que você venha.",
    "00:39:42,00:39:43": "Não há problema.",
    "00:40:10,00:40:10": "Tudo bem?",
    "00:40:23,00:40:24": "Está frio aí?",
    "00:40:25,00:40:25": "Hoje está.",
    "00:40:27,00:40:29": "Ontem estava calor, hoje já está mais frio.",
    "00:40:31,00:40:32": "Foi, foi tranquilo?",
    "00:40:33,00:40:35": "O que está acontecendo com a arma?",
    "00:40:36,00:40:37": "O voo foi tranquilo?",
    "00:40:38,00:40:39": "Foi.",
    "00:40:40,00:40:41": "Foi tranquilo?",
    "00:40:42,00:40:46": "No meu aplicativo não aparecem os nomes, só aparecem.",
    "00:40:46,00:40:48": "Tipo, entrada, roda, não sei o que.",
    "00:40:49,00:40:52": "aí eu solto a 1 no quadro",
    "00:40:52,00:40:53": "que é para ativar o calor",
    "00:40:55,00:40:57": "mas qual foi o número da zona",
    "00:40:57,00:40:58": "que é o corredor",
    "00:41:06,00:41:07": "É, não é fácil.",
    "00:41:09,00:41:10": "Eu vi uma tia de tomada.",
    "00:41:11,00:41:12": "Também.",
    "00:41:13,00:41:14": "Tá bom, filha.",
    "00:41:14,00:41:15": "Muito bem.",
    "00:41:15,00:41:16": "Uma, é...",
    "00:41:17,00:41:20": "Eu quero fazer as contas.",
    "00:41:42,00:41:44": "Atenção!",
    "00:42:20,00:42:21": "É de gasilho!",
    "00:42:23,00:42:24": "Atenção!"
  },
