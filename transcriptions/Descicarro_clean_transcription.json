  "segments": {
    "00:00:01,00:00:04": "Não, não, Matias! Matias!",
    "00:00:06,00:00:07": "Ele chutou ele.",
    "00:00:10,00:00:11": "Não? Tchau!",
    "00:00:29,00:00:30": "Que pisou nele?",
    "00:00:30,00:00:32": "A toque se abacaxa, meu amigo.",
    "00:00:33,00:00:34": "Ai!",
    "00:00:34,00:00:35": "Onde é ele? Deixa eu ver.",
    "00:00:35,00:00:38": "Depois não teve mais medo de a chuca.",
    "00:00:38,00:00:41": "Ela acaba de uma coisa para outra de repente.",
    "00:00:41,00:00:42": "A toque se abacaxa.",
    "00:00:44,00:00:45": "Carinho, vamos?",
    "00:00:45,00:00:47": "Você está com muito medo.",
    "00:00:47,00:00:48": "Fala sua teteira.",
    "00:00:48,00:00:49": "Eu achei que fosse você.",
    "00:00:50,00:00:50": "Fica aí.",
    "00:00:50,00:00:52": "Nós também estamos por aí.",
    "00:00:52,00:00:54": "Não, você vai cair, Matias.",
    "00:00:55,00:00:56": "Vai cair daí.",
    "00:01:03,00:01:06": "Apenas o que for dito, não é o que é dito.",
    "00:01:09,00:01:10": "Hehe.",
    "00:01:26,00:01:27": "É isso.",
    "00:04:01,00:04:02": "Inscreva-se.",
    "00:04:08,00:04:09": ".",
    "00:09:45,00:09:46": "Não há dúvida que o que você está fazendo é um assédio.",
    "00:09:58,00:09:58": "Não!",
    "00:10:00,00:10:01": "Não, Matias.",
    "00:10:02,00:10:03": "Você não quer mais?",
    "00:10:18,00:10:19": "Não, só lembrando o que eu falei.",
    "00:10:25,00:10:28": "Não está tirando, só perguntar aí. Nossa, não pode contar?",
    "00:10:42,00:10:43": "E eu não tenho nada.",
    "00:10:47,00:10:48": "Eu não tenho nada.",
    "00:10:48,00:10:48": "Eu não tenho nada.",
    "00:11:03,00:11:06": "E aí",
    "00:11:10,00:11:17": "Você falando, você que começou a tocar na punta, você que ficou nervosa, você que ficou...",
    "00:11:20,00:11:21": "Não, porque é o quê?",
    "00:11:22,00:11:23": "Eu estava no meu mó, quando você me falou.",
    "00:11:23,00:11:24": "Eu falei o quê?",
    "00:11:25,00:11:26": "Eu fui tocar onde?",
    "00:11:27,00:11:28": "Quando eu perguntei, você sabe?",
    "00:11:28,00:11:28": "Não é o que eu sei?",
    "00:11:29,00:11:30": "Não, nunca.",
    "00:11:38,00:11:40": "Nossa Senhora!",
    "00:11:44,00:11:46": "Criando? Vai ver, não sei, guarda?",
    "00:11:58,00:11:59": "Não.",
    "00:12:16,00:12:17": "A parte de dar início.",
    "00:12:25,00:12:26": "Obrigado.",
    "00:12:42,00:12:44": "E aí",
    "00:12:48,00:12:49": "Não vou dar o que você quer.",
    "00:13:08,00:13:10": "Atenção, a você não...",
    "00:13:11,00:13:12": "É?",
    "00:13:15,00:13:16": "Tem o quê?",
    "00:13:18,00:13:18": "Por quê?",
    "00:13:24,00:13:24": "Não.",
    "00:13:29,00:13:35": "Não é possível.",
