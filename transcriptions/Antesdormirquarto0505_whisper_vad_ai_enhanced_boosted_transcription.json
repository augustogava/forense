    "00:03:10,00:03:12": "Não há nenhum problema.",
    "00:04:48,00:04:50": "Não é tchau tchau!",
    "00:04:53,00:04:55": "Não se esqueça de deixar seu like e compartilhar o vídeo.",
    "00:05:05,00:05:06": "Tchau, tchau.",
    "00:05:30,00:05:31": "Submarino",
    "00:07:27,00:07:28": "Atenção!",
    "00:07:42,00:07:45": "Por exemplo, eu tenho um pai que não sabe falar com o pai.",
    "00:07:48,00:07:48": "Oi!",
    "00:07:55,00:07:56": "Atenção!",
    "00:08:03,00:08:05": "Atenção!",
    "00:08:07,00:08:11": "O que você quer saber mais?",
    "00:08:38,00:08:39": "Tchau, tchau, tchau, tchau.",
    "00:09:06,00:09:08": "Atenção!",
    "00:13:00,00:13:00": ".",
    "00:15:06,00:15:06": ".",
    "00:17:00,00:17:01": "Descubra o que você acha do vídeo e compartilhe com seus amigos.",
    "00:17:04,00:17:04": "Não tem som para ele.",
    "00:19:46,00:19:46": "Tchau!",
    "00:22:14,00:22:15": "Eu não entendo nada."
