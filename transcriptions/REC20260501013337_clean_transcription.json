    "00:01:35,00:01:35": ".",
    "00:06:51,00:06:51": ".",
    "00:10:34,00:10:37": "E o Matias? Vai buscar ou eu vou buscar?",
    "00:10:40,00:10:40": "Eu vou buscar aí.",
    "00:10:46,00:10:46": "Adiós.",
    "00:10:49,00:10:49": "Passa uma...",
    "00:10:53,00:10:54": "Vai voltar pra cá?",
    "00:10:58,00:10:58": "Até mais, galera. Tchau, tchau.",
    "00:13:47,00:13:47": ".",
    "00:14:29,00:14:30": "Ainda não é possível.",
    "00:15:28,00:15:29": "Acompanhe o programa em seus redes sociais.",
    "00:25:12,00:25:12": ".",
    "00:28:56,00:28:56": "Acordou?",
    "00:29:56,00:29:56": "Agradecimentos a todos os que participaram do programa.",
    "00:30:14,00:30:16": "O... o coelho não tinha pra ele?",
    "00:32:22,00:32:27": "Eu não achei que era razão, nem lembrei de falar. Eu achei que você pudesse...",
    "00:32:37,00:32:40": "Aí eu comecei a pensar em refugiar ela em algum lugar.",
    "00:32:42,00:32:46": "Ai, sou soubesse, eu tinha que abrir a doela, que a gente decidiu ir, né?",
    "00:32:47,00:32:49": "Não, mas eu já falei, eu falei.",
    "00:34:51,00:34:51": ".",
    "00:35:10,00:35:10": ".",
    "00:36:53,00:36:53": "Não há problema.",
    "00:38:02,00:38:02": "Acompanhe o vídeo."
  },
