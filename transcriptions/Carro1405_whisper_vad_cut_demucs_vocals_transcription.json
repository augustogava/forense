    "00:41:38,00:41:38": ".",
    "00:58:52,00:58:52": "Não!",
    "01:01:58,01:01:59": "Atenção!",
    "01:02:04,01:02:07": "Descrivam as questões que lhes ocorreram em seus livros.",
    "01:02:09,01:02:09": ".",
